rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Allow client to send emails
    match /mail/{mailId} {
      allow create: if true;
    }

    // Allow client to submit budget requests
    match /refcon_budget/{budgetId} {
      allow create: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
